// @id=wr_1773886095461229720 @name=vivaldi-stable
window-rule {
    match app-id="^vivaldi-stable$"
    open-maximized true
}

// @id=wr_1773886129640629340 @name=discord
window-rule {
    match app-id="^discord$"
    open-fullscreen true
}
